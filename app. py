from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
import time
import random

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.get("/")
def home():
    return {"status": "Expiry Hero ANT Backend Running", "time": time.time()}

@app.get("/health")
def health():
    return {"status": "ok"}

@app.post("/connect")
def connect_ant():
    return {"status": "CONNECTED", "session_id": f"ANT_{int(time.time())}", "funds": {"cash": 50000}}

@app.post("/place_order")
def place_order():
    return {"status": "EXECUTED_PAPER", "order_id": f"PAPER{int(time.time())}{random.randint(100,999)}"}

@app.post("/square_off")
def square_off():
    return {"status": "SQUARED_OFF"}

@app.get("/positions")
def positions():
    return {"positions": []}
